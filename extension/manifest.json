{
  "manifest_version": 3,
  "name": "Sadeed:: Anomaly Detector",
  "version": "1.0.0",
  "description": "Scan form data and Excel files for anomalies and data entry errors in Labour Force Survey records",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://sadeed.aldharrab.co.uk/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["upload.html", "lib/xlsx.full.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
