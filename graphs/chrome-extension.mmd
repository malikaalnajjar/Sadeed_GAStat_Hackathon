        TAB_SCAN["Tab: Scan Results<br/>Per-Strategy Breakdown"]
        TAB_UPLOAD["Tab: Upload Excel<br/>Batch Processing"]
    end

    subgraph Backend["FastAPI Backend"]
        DETECT["/anomalies/detect"]
        HEALTH["/anomalies/health"]
    end

    FORM -->|"Scans fields"| CS
    BTN -->|"Click"| CS
    CS -->|"DETECT message"| BG
    BG -->|"HTTP POST"| DETECT
