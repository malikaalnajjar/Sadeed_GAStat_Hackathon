        FORM["HTML Form /<br/>Google Form"]
        BTN["Injected Button<br/>Scan Form"]
        OVERLAY["Results Overlay<br/>Green/Red Highlights"]
    end

    subgraph Extension["Chrome Extension (Manifest V3)"]
        CS["content.js<br/>Form Scanner"]
        BG["background.js<br/>Service Worker"]
